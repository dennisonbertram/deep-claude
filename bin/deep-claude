#!/usr/bin/env bash
set -euo pipefail

# deep-claude — drive Claude Code with alternate models.
#
#   deep-claude                         run on your default OpenRouter model
#   deep-claude --model gemini [args]   pick a model for this run (alias or id)
#   deep-claude pick                    tabbed picker: OpenRouter + endpoints, ＋ add new
#   deep-claude models <add|remove|list|default>   curate the OpenRouter set
#   deep-claude endpoints add                      add a custom endpoint interactively (name + URL + key + models)
#   deep-claude endpoints pick <name>              browse that endpoint's /v1/models in the picker
#   deep-claude endpoints <add|remove|list>        manage personal endpoints
#   deep-claude --endpoint deepseek --model deepseek-v4-pro   use a saved endpoint
#   deep-claude --base-url URL [--api-key-env VAR] --model M  ad-hoc endpoint
#
# OpenRouter is the default path. Any other Anthropic-compatible endpoint
# (DeepSeek-direct, a local Ollama, a self-hosted gateway) is a "personal
# endpoint" you reach with --endpoint / --base-url.

# Resolve symlinks so this works when installed via symlink (~/.local/bin/...).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
PROJECT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="${DEEP_CLAUDE_ENV_FILE:-$PROJECT_DIR/.env}"
# Isolated home for Claude Code state (config/cache/data + our settings.json).
# Overridable so tests can run against a throwaway dir instead of the real home.
STATE_DIR="${DEEP_CLAUDE_STATE_DIR:-$PROJECT_DIR/.deep-claude-home}"

usage() {
  cat <<'EOF'
Usage:
  deep-claude [--model ALIAS|ID] [claude args...]      run on OpenRouter (default)
  deep-claude cli                                      first-run setup wizard (key + models)
  deep-claude pick                                     tabbed picker: OpenRouter + endpoints + ＋add (TUI)
  deep-claude models <add|remove|list|default> ...     curate the OpenRouter set
  deep-claude endpoints <add|remove|list> ...          manage personal endpoints
  deep-claude endpoints pick NAME                      browse an endpoint's models (TUI)
  deep-claude --endpoint NAME [--model M] [args...]    use a saved endpoint
  deep-claude --base-url URL [--api-key-env VAR] [--api-key KEY] --model M [args...]

OpenRouter is the default. Set it up once:
  security add-generic-password -s deep-router -a openrouter -U -w   # or OPENROUTER_API_KEY in .env
  deep-claude pick                                                   # choose your models
  deep-claude                                                        # go

Personal endpoints (DeepSeek-direct, local models, self-hosted) are second-tier:
  deep-claude endpoints add                                          # interactive: name + URL + key + models
  deep-claude endpoints add deepseek https://api.deepseek.com/anthropic DEEPSEEK_API_KEY
  deep-claude --endpoint deepseek --model deepseek-v4-pro

Use your existing Claude setup (skills, plugins, agents, workflows, MCP servers):
  Inherit is ON by default. Your ~/.claude skills/agents/workflows/plugins/hooks/
  rules/CLAUDE.md/MCP servers are linked into the isolated home each launch.
  Your Anthropic login and credentials are never imported.
  deep-claude --no-inherit               opt out for one run, or set DEEP_CLAUDE_INHERIT=0 in .env

Session sharing (ON by default):
  Transcript history (projects/) is symlinked to ~/.claude/projects so sessions
  started in deep-claude are resumable with plain `claude --resume` and vice-versa.
  deep-claude --no-share-sessions        opt out for one run, or set DEEP_CLAUDE_SHARE_SESSIONS=0
  NOTE: ~/.claude/settings.json and .credentials.json are never shared (auth stays isolated).
  NOTE: sessions/ (live PID registry) and file-history/ stay isolated.
  Aborted sessions that never flushed a .jsonl won't appear in either store.

Filesystem sandbox (opt-in):
  deep-claude --sandbox [...]            confine writes to cwd/state/tmp; reads/exec/net allowed.
  deep-claude --no-sandbox [...]         explicitly disable (default).
  DEEP_CLAUDE_SANDBOX=1                  enable via .env.
  DEEP_CLAUDE_SANDBOX_NET=loopback       restrict net to loopback only (Darwin only).
  FAIL CLOSED: if --sandbox is requested but sandbox-exec (macOS) or bwrap (Linux)
  is not on PATH, deep-claude exits non-zero rather than running unconfined.

Environment:
  OPENROUTER_API_KEY         default-path key (env, .env, or Keychain -s deep-router -a openrouter).
  DEEP_CLAUDE_INHERIT        "0" => skip linking ~/.claude config (default: "1" = inherit).
  DEEP_CLAUDE_SHARE_SESSIONS "0" => don't symlink projects/ to ~/.claude/projects (default: "1").
  DEEP_CLAUDE_SANDBOX        "1" => enable filesystem sandbox (default: "0").
  DEEP_CLAUDE_SANDBOX_NET    "loopback" => loopback-only net in sandbox (Darwin only).
  CLAUDE_BIN                 override the claude executable.
EOF
}

# True when session/config inheritance is enabled (default ON).
inherit_on() { [[ "${DEEP_CLAUDE_INHERIT:-1}" != "0" ]]; }

# Load .env (KEY=value lines) into the environment.
load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi
}

# --- .env get/set helpers (comma-list aware) --------------------------------
env_get() {
  local key="$1" line val=""
  [[ -f "$ENV_FILE" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" == "$key="* ]] && val="${line#"$key"=}"
  done <"$ENV_FILE"
  # Strip ALL surrounding quotes, not just one. env_set wraps in a single pair,
  # but a value that picked up stray quotes from an earlier bug would otherwise
  # keep them forever (read strips one, write adds one back). Stripping every
  # surrounding quote lets such values self-heal on the next write. Our values
  # (model ids, aliases, URLs) never legitimately contain a double quote.
  while [[ "$val" == '"'* ]]; do val="${val#\"}"; done
  while [[ "$val" == *'"' ]]; do val="${val%\"}"; done
  printf '%s' "$val"
}

env_set() {
  local key="$1" value="$2" tmp found=0 line
  [[ -f "$ENV_FILE" ]] || : >"$ENV_FILE"
  tmp="$(mktemp)"
  # Quote the value: .env is sourced, so unquoted shell metacharacters in a
  # value (| in endpoint specs, & in URLs) would be interpreted. env_get strips
  # the quotes back off on read.
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "$key="* ]]; then
      printf '%s="%s"\n' "$key" "$value" >>"$tmp"
      found=1
    else
      printf '%s\n' "$line" >>"$tmp"
    fi
  done <"$ENV_FILE"
  ((found)) || printf '%s="%s"\n' "$key" "$value" >>"$tmp"
  mv "$tmp" "$ENV_FILE"
}

join_csv() {
  local out="" item
  for item in "$@"; do
    [[ -z "$item" ]] && continue
    out="${out:+$out,}$item"
  done
  printf '%s' "$out"
}

# Uppercase, env-var-safe slug of an endpoint name (e.g. "deepseek-custom" ->
# "DEEPSEEK_CUSTOM"). Used to build per-endpoint env-var names.
ep_slug() {
  printf '%s' "$1" | LC_ALL=C tr 'a-z' 'A-Z' | LC_ALL=C tr -c 'A-Z0-9' '_'
}

# Derive a stable env-var name for an endpoint's key from its name, e.g.
# "deepseek" -> "DEEP_KEY_DEEPSEEK". Used by the interactive endpoint flow so
# the user never has to invent a variable name.
keyenv_for() { printf 'DEEP_KEY_%s' "$(ep_slug "$1")"; }

# --- OpenRouter model curation ----------------------------------------------
models_list() {
  local models aliases def
  models="$(env_get ROUTER_MODELS)"
  aliases="$(env_get ROUTER_ALIASES)"
  def="$(env_get ROUTER_DEFAULT_MODEL)"
  echo "Curated models (ROUTER_MODELS):"
  if [[ -n "$models" ]]; then
    IFS=',' read -ra arr <<<"$models"
    for m in ${arr[@]+"${arr[@]}"}; do [[ -n "${m// /}" ]] && echo "  ${m// /}"; done
  else echo "  (none — run: deep-claude pick)"; fi
  echo "Aliases (ROUTER_ALIASES):"
  if [[ -n "$aliases" ]]; then
    IFS=',' read -ra arr <<<"$aliases"
    for a in ${arr[@]+"${arr[@]}"}; do [[ -n "${a// /}" ]] && echo "  ${a// /}"; done
  else echo "  (none)"; fi
  echo "Default (ROUTER_DEFAULT_MODEL): ${def:-(none)}"
}

models_add() {
  local id="$1" alias="${2:-}"
  [[ -z "$id" ]] && { echo "deep-claude: 'models add' needs an OpenRouter model id" >&2; exit 2; }
  local cur kept=() m
  cur="$(env_get ROUTER_MODELS)"
  IFS=',' read -ra arr <<<"$cur"
  for m in ${arr[@]+"${arr[@]}"}; do
    m="${m// /}"; [[ -z "$m" || "$m" == "$id" ]] && continue; kept+=("$m")
  done
  kept+=("$id")
  env_set ROUTER_MODELS "$(join_csv ${kept[@]+"${kept[@]}"})"
  if [[ -n "$alias" ]]; then
    local acur akept=() p
    acur="$(env_get ROUTER_ALIASES)"
    IFS=',' read -ra aarr <<<"$acur"
    for p in ${aarr[@]+"${aarr[@]}"}; do
      p="${p// /}"; [[ -z "$p" || "${p%%=*}" == "$alias" ]] && continue; akept+=("$p")
    done
    akept+=("$alias=$id")
    env_set ROUTER_ALIASES "$(join_csv ${akept[@]+"${akept[@]}"})"
  fi
  echo "Added ${id}${alias:+ (alias: $alias)}."
  models_list
}

models_remove() {
  local token="$1"
  [[ -z "$token" ]] && { echo "deep-claude: 'models remove' needs an id or alias" >&2; exit 2; }
  local acur p akept=() target="$token"
  acur="$(env_get ROUTER_ALIASES)"
  IFS=',' read -ra aarr <<<"$acur"
  for p in ${aarr[@]+"${aarr[@]}"}; do
    p="${p// /}"; [[ -z "$p" ]] && continue
    [[ "${p%%=*}" == "$token" ]] && target="${p#*=}"
  done
  akept=()
  for p in ${aarr[@]+"${aarr[@]}"}; do
    p="${p// /}"; [[ -z "$p" ]] && continue
    [[ "${p%%=*}" == "$token" || "${p#*=}" == "$target" ]] && continue
    akept+=("$p")
  done
  env_set ROUTER_ALIASES "$(join_csv ${akept[@]+"${akept[@]}"})"
  local cur kept=() m
  cur="$(env_get ROUTER_MODELS)"
  IFS=',' read -ra arr <<<"$cur"
  for m in ${arr[@]+"${arr[@]}"}; do
    m="${m// /}"; [[ -z "$m" || "$m" == "$target" || "$m" == "$token" ]] && continue; kept+=("$m")
  done
  env_set ROUTER_MODELS "$(join_csv ${kept[@]+"${kept[@]}"})"
  echo "Removed ${token}."
  models_list
}

models_default() {
  local token="$1"
  [[ -z "$token" ]] && { echo "deep-claude: 'models default' needs an alias or id" >&2; exit 2; }
  env_set ROUTER_DEFAULT_MODEL "$token"
  echo "Default model set to ${token}."
}

models_dispatch() {
  local sub="${1:-list}"
  [[ $# -gt 0 ]] && shift || true
  case "$sub" in
    list) models_list ;;
    add) models_add "${1:-}" "${2:-}" ;;
    remove | rm) models_remove "${1:-}" ;;
    default) models_default "${1:-}" ;;
    *) echo "deep-claude: unknown 'models' subcommand: $sub" >&2; usage; exit 2 ;;
  esac
}

# --- Personal endpoints (DEEP_ENDPOINTS = name|url|KEYENV,...) ---------------
endpoint_lookup() { # name -> prints "url|keyenv" or empty
  local name="$1" cur p
  cur="$(env_get DEEP_ENDPOINTS)"
  IFS=',' read -ra arr <<<"$cur"
  for p in ${arr[@]+"${arr[@]}"}; do
    [[ "${p%%|*}" == "$name" ]] && { printf '%s' "${p#*|}"; return 0; }
  done
  return 1
}

endpoints_list() {
  local cur p
  cur="$(env_get DEEP_ENDPOINTS)"
  echo "Personal endpoints (DEEP_ENDPOINTS):"
  if [[ -z "$cur" ]]; then echo "  (none)"; return; fi
  IFS=',' read -ra arr <<<"$cur"
  for p in ${arr[@]+"${arr[@]}"}; do
    [[ -z "$p" ]] && continue
    local name="${p%%|*}" rest="${p#*|}" url="${p#*|}" keyenv models default slug
    url="${rest%%|*}"; keyenv="${rest#*|}"
    printf '  %-12s %s%s\n' "$name" "$url" "${keyenv:+   (key: \$$keyenv)}"
    slug="$(ep_slug "$name")"
    models="$(env_get "DEEP_EP_MODELS_$slug")"; default="$(env_get "DEEP_EP_DEFAULT_$slug")"
    if [[ -n "$models" ]]; then
      printf '  %-12s models: %s%s\n' "" "${models//,/, }" "${default:+   (default: $default)}"
    fi
  done
}

endpoints_add() {
  local name="$1" url="$2" keyenv="${3:-}"
  [[ -z "$name" || -z "$url" ]] && { echo "deep-claude: 'endpoints add' needs <name> <base-url> [KEY_ENV_VAR]" >&2; exit 2; }
  case "$name$url$keyenv" in *,* | *\|*) echo "deep-claude: name/url/key-env must not contain ',' or '|'" >&2; exit 2 ;; esac
  local cur kept=() p
  cur="$(env_get DEEP_ENDPOINTS)"
  IFS=',' read -ra arr <<<"$cur"
  for p in ${arr[@]+"${arr[@]}"}; do
    [[ -z "$p" || "${p%%|*}" == "$name" ]] && continue; kept+=("$p")
  done
  kept+=("$name|$url|$keyenv")
  env_set DEEP_ENDPOINTS "$(join_csv ${kept[@]+"${kept[@]}"})"
  echo "Saved endpoint '$name'."
  local ep_default; ep_default="$(env_get "DEEP_EP_DEFAULT_$(ep_slug "$name")")"
  if [[ -n "$ep_default" ]]; then
    echo "  · use it directly:   deep-claude --endpoint $name            # default: $ep_default"
    echo "    switch models in-session with /model, or per run with --model <id>"
  else
    echo "  · use it directly:   deep-claude --endpoint $name --model <id>"
  fi
  echo "  · and in OpenRouter mode, '$name/*' models now route through this"
  echo "    endpoint (your key) instead of OpenRouter — often faster."
  if [[ -n "$keyenv" ]]; then
    # Is the key actually resolvable yet? (shell env, .env, or Keychain)
    local kv="${!keyenv:-}"
    [[ -z "$kv" ]] && kv="$(env_get "$keyenv")"
    if [[ -z "$kv" ]] && command -v security >/dev/null 2>&1; then
      kv="$(security find-generic-password -s deep-claude -a "$name" -w 2>/dev/null || true)"
    fi
    if [[ -n "$kv" ]]; then
      echo "  · key (\$$keyenv) found ✓ — you're ready to go."
    else
      echo "  · key (\$$keyenv) NOT found yet. Add it one of these ways:"
      echo "      security add-generic-password -s deep-claude -a $name -U -w   # Keychain (paste key)"
      echo "      echo '$keyenv=\"sk-...\"' >> \"$ENV_FILE\""
    fi
  fi
  endpoints_list
}

# Interactive `endpoints add`: prompt for a name, base URL, and (optionally) an
# API key, then store the key in Keychain (preferred) or .env and save the
# endpoint. Lets you add a custom endpoint without knowing the positional-arg
# syntax or the env-var indirection.
endpoints_add_interactive() {
  [[ -t 0 ]] || { echo "deep-claude: 'endpoints add' needs a terminal for interactive mode (or pass: add <name> <url> [KEY_ENV_VAR])" >&2; exit 2; }
  printf '\n  \033[1mAdd a custom endpoint\033[0m (any Anthropic-compatible URL)\n\n'
  local name url key keyenv
  printf '  Name (e.g. deepseek): '; read -r name
  [[ -z "$name" ]] && { echo "deep-claude: name is required" >&2; exit 2; }
  case "$name" in
    *[,\|\ ]*) echo "deep-claude: name must not contain spaces, ',' or '|'" >&2; exit 2 ;;
  esac
  printf '  Base URL (e.g. https://api.deepseek.com/anthropic): '; read -r url
  [[ -z "$url" ]] && { echo "deep-claude: base URL is required" >&2; exit 2; }
  case "$url" in
    *[,\|]*) echo "deep-claude: URL must not contain ',' or '|'" >&2; exit 2 ;;
  esac
  printf '  API key (hidden — leave blank for keyless endpoints like local Ollama): '
  read -rs key; printf '\n'

  keyenv=""
  if [[ -n "$key" ]]; then
    keyenv="$(keyenv_for "$name")"
    if command -v security >/dev/null 2>&1 \
      && security add-generic-password -s deep-claude -a "$name" -U -w "$key" >/dev/null 2>&1; then
      printf '  · key stored in Keychain (service deep-claude, account %s)\n' "$name"
    else
      env_set "$keyenv" "$key"
      printf '  · key stored in %s\n' "$ENV_FILE"
    fi
  fi

  # Models: browse the endpoint's own catalog (same picker as OpenRouter), or
  # type ids by hand. Either way you can switch between them in-session (/model)
  # and launch without typing --model.
  local slug; slug="$(ep_slug "$name")"
  if command -v node >/dev/null 2>&1; then
    local browse
    printf '  Browse this endpoint'\''s models now? [Y/n]: '; read -r browse
    if [[ -z "$browse" || "$browse" == [Yy]* ]]; then
      DEEP_PICK_MODE=endpoint DEEP_PICK_ENDPOINT_NAME="$name" DEEP_PICK_BASE_URL="$url" \
        DEEP_PICK_API_KEY="$key" DEEP_CLAUDE_ENV_FILE="$ENV_FILE" node "$SCRIPT_DIR/deep-claude-pick" || true
      load_env
    fi
  fi
  # Fall back to manual entry if nothing got saved (declined, no node, or the
  # endpoint exposes no /models API).
  if [[ -z "$(env_get "DEEP_EP_MODELS_$slug")" ]]; then
    local models first default
    printf '  Model ids — comma-separated, optional (e.g. deepseek-chat,deepseek-reasoner): '
    read -r models; models="${models//[[:space:]]/}"
    if [[ -n "$models" ]]; then
      case "$models" in *\|*) echo "deep-claude: model ids must not contain '|'" >&2; exit 2 ;; esac
      env_set "DEEP_EP_MODELS_$slug" "$models"
      first="${models%%,*}"
      printf '  Default model [%s]: ' "$first"; read -r default
      default="${default//[[:space:]]/}"; [[ -z "$default" ]] && default="$first"
      env_set "DEEP_EP_DEFAULT_$slug" "$default"
      printf '  · %s model(s) saved; default: %s\n' "$(printf '%s' "$models" | tr ',' '\n' | grep -c .)" "$default"
    fi
  fi

  printf '\n'
  endpoints_add "$name" "$url" "$keyenv"
}

endpoints_remove() {
  local name="$1"
  [[ -z "$name" ]] && { echo "deep-claude: 'endpoints remove' needs a name" >&2; exit 2; }
  local cur kept=() p
  cur="$(env_get DEEP_ENDPOINTS)"
  IFS=',' read -ra arr <<<"$cur"
  for p in ${arr[@]+"${arr[@]}"}; do
    [[ -z "$p" || "${p%%|*}" == "$name" ]] && continue; kept+=("$p")
  done
  env_set DEEP_ENDPOINTS "$(join_csv ${kept[@]+"${kept[@]}"})"
  echo "Removed endpoint '$name'."
  endpoints_list
}

endpoints_dispatch() {
  local sub="${1:-list}"
  [[ $# -gt 0 ]] && shift || true
  case "$sub" in
    list) endpoints_list ;;
    add)
      if [[ $# -eq 0 ]]; then endpoints_add_interactive
      else endpoints_add "${1:-}" "${2:-}" "${3:-}"; fi ;;
    pick | models) run_endpoint_pick "${1:-}" ;;
    remove | rm) endpoints_remove "${1:-}" ;;
    *) echo "deep-claude: unknown 'endpoints' subcommand: $sub" >&2; usage; exit 2 ;;
  esac
}

# --- key resolution + picker ------------------------------------------------
resolve_openrouter_key() {
  local key="${OPENROUTER_API_KEY:-}"
  [[ "$key" == "sk-or-..." ]] && key=""
  if [[ -z "$key" ]] && command -v security >/dev/null 2>&1; then
    key="$(security find-generic-password -s deep-router -a openrouter -w 2>/dev/null || true)"
  fi
  printf '%s' "$key"
}

run_pick() {
  command -v node >/dev/null 2>&1 || { echo "deep-claude: node is required for the picker" >&2; exit 1; }
  # The hub is a tabbed picker over OpenRouter + every saved endpoint, with an
  # inline "＋ Add" tab. An OpenRouter key is optional (that tab just shows a
  # notice when absent), so you can manage endpoints here without one.
  local key; key="$(resolve_openrouter_key)"
  export_endpoint_keys   # so the hub can list each endpoint's models with your key
  OPENROUTER_API_KEY="$key" DEEP_PICK_MODE=hub DEEP_CLAUDE_ENV_FILE="$ENV_FILE" exec node "$SCRIPT_DIR/deep-claude-pick"
}

# Resolve a personal endpoint's key from its key-env var (shell, .env) or
# Keychain (service deep-claude, account=<name>). Prints the key (or empty).
resolve_endpoint_key() {
  local name="$1" keyenv="$2" key=""
  if [[ -n "$keyenv" ]]; then
    key="${!keyenv:-}"
    [[ -z "$key" ]] && key="$(env_get "$keyenv")"
  fi
  if [[ -z "$key" ]] && command -v security >/dev/null 2>&1; then
    key="$(security find-generic-password -s deep-claude -a "$name" -w 2>/dev/null || true)"
  fi
  printf '%s' "$key"
}

# Browse a saved endpoint's own /v1/models in the picker TUI and save the
# selection (DEEP_EP_MODELS_<slug> / DEEP_EP_DEFAULT_<slug>).
run_endpoint_pick() {
  local name="$1"
  [[ -z "$name" ]] && { echo "deep-claude: 'endpoints pick' needs an endpoint name (see: deep-claude endpoints list)" >&2; exit 2; }
  command -v node >/dev/null 2>&1 || { echo "deep-claude: node is required for the picker" >&2; exit 1; }
  local spec; spec="$(endpoint_lookup "$name")" || { echo "deep-claude: no saved endpoint '$name' (see: deep-claude endpoints list)" >&2; exit 1; }
  local url="${spec%%|*}" keyenv="${spec#*|}" key
  key="$(resolve_endpoint_key "$name" "$keyenv")"
  DEEP_PICK_MODE=endpoint DEEP_PICK_ENDPOINT_NAME="$name" DEEP_PICK_BASE_URL="$url" \
    DEEP_PICK_API_KEY="$key" DEEP_CLAUDE_ENV_FILE="$ENV_FILE" node "$SCRIPT_DIR/deep-claude-pick"
}

# Ensure a key and a curated model set exist, running the key wizard and/or the
# model picker as needed. Each TUI runs as its own clean foreground process (no
# nesting), so raw-mode input can't leak between them. Pass "interactive" to
# always run the picker and print a closing note (the explicit `cli` command).
run_setup() {
  command -v node >/dev/null 2>&1 || { echo "deep-claude: node is required for setup" >&2; exit 1; }
  local interactive=""
  [[ "${1:-}" == "interactive" ]] && interactive=1

  # The hub picker is the whole setup now: it manages the OpenRouter key (press
  # `e` on the OpenRouter provider) and every personal endpoint (＋ Add provider)
  # in one place, then lets you drill into each provider's model list. So both
  # `deep-claude cli` and the first-run auto-setup just hand straight off to it.
  local key; key="$(resolve_openrouter_key)"
  export_endpoint_keys
  OPENROUTER_API_KEY="$key" DEEP_PICK_MODE=hub DEEP_PICK_QUIET=1 DEEP_CLAUDE_ENV_FILE="$ENV_FILE" node "$SCRIPT_DIR/deep-claude-pick" || true
  load_env
  key="$(resolve_openrouter_key)"

  if [[ -n "$interactive" ]]; then
    printf '\n  \033[32m✓\033[0m Setup complete. Run: \033[1mdeep-claude\033[0m\n\n'
    return 0
  fi
  # First-run auto-setup: only proceed to launch if a key actually got set.
  [[ -z "$key" ]] && return 1
  return 0
}

# Resolve a raw model token (alias name, full id, or empty) into an OpenRouter
# model id, consulting ROUTER_ALIASES and ROUTER_DEFAULT_MODEL.
# Resolve each personal-endpoint's key (env, .env, or Keychain service
# "deep-claude" account=<endpoint name>) and export it, so the proxy can route
# that provider's models directly with your own credentials.
export_endpoint_keys() {
  local cur p name keyenv val
  cur="$(env_get DEEP_ENDPOINTS)"
  [[ -z "$cur" ]] && return 0
  IFS=',' read -ra arr <<<"$cur"
  for p in ${arr[@]+"${arr[@]}"}; do
    [[ -z "$p" ]] && continue
    name="${p%%|*}"
    keyenv="${p##*|}"
    [[ -z "$keyenv" || "$keyenv" == "$p" ]] && continue
    val="${!keyenv:-}"
    [[ -z "$val" ]] && val="$(env_get "$keyenv")"
    if [[ -z "$val" ]] && command -v security >/dev/null 2>&1; then
      val="$(security find-generic-password -s deep-claude -a "$name" -w 2>/dev/null || true)"
    fi
    # Use if/fi, not `[[ ]] && export`: as the loop's last statement the latter
    # returns 1 when an endpoint has no key, which under `set -e` would abort the
    # whole wrapper (e.g. `deep-claude cli` exiting before the picker appears).
    if [[ -n "$val" ]]; then export "$keyenv=$val"; fi
  done
  return 0
}

resolve_router_model() {
  local m="$1" aliases p
  [[ -z "$m" ]] && m="$(env_get ROUTER_DEFAULT_MODEL)"
  aliases="$(env_get ROUTER_ALIASES)"
  if [[ -n "$aliases" ]]; then
    IFS=',' read -ra prs <<<"$aliases"
    for p in ${prs[@]+"${prs[@]}"}; do
      p="${p// /}"; [[ -z "$p" ]] && continue
      [[ "${p%%=*}" == "$m" ]] && { m="${p#*=}"; break; }
    done
  fi
  printf '%s' "$m"
}

# True if something is already listening on 127.0.0.1:<port>.
port_in_use() {
  (exec 3<>"/dev/tcp/127.0.0.1/$1") 2>/dev/null
}

# Find a free local port, starting at ROUTER_PORT (default 8787) and stepping up.
# 8787 is a popular default (wrangler/workerd, etc.), so we never assume it.
find_free_port() {
  local p="${ROUTER_PORT:-8787}" i
  for i in $(seq 0 200); do
    port_in_use "$p" || { printf '%s' "$p"; return 0; }
    p=$((p + 1))
  done
  printf '%s' "${ROUTER_PORT:-8787}"
}

# Bring the user's real ~/.claude config (skills, plugins, agents, workflows,
# rules, hooks, commands, settings, CLAUDE.md) into the isolated home via
# symlinks, and merge their MCP servers — but NOT the Anthropic login/history
# (which would conflict with the OpenRouter routing). Opt in with
# DEEP_CLAUDE_INHERIT=1 (.env) or the --inherit flag.
inherit_config() {
  local real="$HOME/.claude" dest="$STATE_DIR/home/.claude"
  [[ -d "$real" ]] || return 0
  mkdir -p "$dest"
  # settings.json is handled by ensure_statusline (copy+merge, not a symlink, so
  # we can add our statusline without writing to your real file).
  local item src dst
  for item in skills agents workflows rules hooks commands plugins CLAUDE.md; do
    src="$real/$item"; dst="$dest/$item"
    [[ -e "$src" ]] || continue
    if [[ -L "$dst" ]]; then
      ln -sfn "$src" "$dst"           # refresh existing symlink
    else
      [[ -e "$dst" ]] && rm -rf "$dst" # drop the isolated default, then link
      ln -s "$src" "$dst"
    fi
  done
  # Merge MCP servers from ~/.claude.json into the isolated config's .claude.json
  # (config wins on conflict, so deep-claude-side additions are preserved).
  if command -v node >/dev/null 2>&1 && [[ -f "$HOME/.claude.json" ]]; then
    DC_SRC="$HOME/.claude.json" DC_DST="$dest/.claude.json" node -e '
      const fs=require("fs");
      let src={}; try{src=JSON.parse(fs.readFileSync(process.env.DC_SRC,"utf8"))}catch(e){}
      let dst={}; try{dst=JSON.parse(fs.readFileSync(process.env.DC_DST,"utf8"))}catch(e){}
      dst.mcpServers=Object.assign({}, src.mcpServers||{}, dst.mcpServers||{});
      fs.writeFileSync(process.env.DC_DST, JSON.stringify(dst,null,2));
    ' 2>/dev/null || true
  fi
}

# Share transcript store with the real ~/.claude so sessions started in
# deep-claude are visible from plain `claude --resume` and vice-versa.
# Only projects/ is shared; auth, settings, and sessions/ stay isolated.
# On first run, any existing isolated projects are migrated into the real store.
# Opt out with DEEP_CLAUDE_SHARE_SESSIONS=0.
share_sessions() {
  local real="$HOME/.claude" dest="$STATE_DIR/home/.claude"
  [[ -d "$real" ]] || return 0
  mkdir -p "$dest" "$real/projects"
  local src="$real/projects" dst="$dest/projects"
  if [[ -L "$dst" ]]; then
    ln -sfn "$src" "$dst"
  elif [[ -e "$dst" ]]; then
    # First migration: merge existing isolated transcripts into the shared store
    # at FILE granularity (so a project dir present in BOTH homes keeps every
    # transcript), never clobbering a real-home file, then replace with a symlink.
    # File-level (not dir-level) is essential: session ids are unique, so distinct
    # transcripts in a colliding project dir must all survive — a dir-level skip
    # followed by rm -rf would silently delete them.
    if [[ -d "$dst" ]]; then
      local f rel tgt
      while IFS= read -r -d '' f; do
        rel="${f#"$dst"/}"; tgt="$src/$rel"
        if [[ ! -e "$tgt" ]]; then mkdir -p "$(dirname "$tgt")"; mv "$f" "$tgt"; fi
      done < <(find "$dst" -type f -print0 2>/dev/null)
    fi
    rm -rf "$dst"
    ln -s "$src" "$dst"
  else
    ln -s "$src" "$dst"
  fi
  return 0
}

# Add the deep-claude statusline (live "direct vs openrouter" route indicator)
# to the isolated settings.json. Bases off your real settings when inheriting
# (copy + merge, never touching your file) and keeps your own statusline if you
# already have one. When inheriting, strips top-level model/apiKeyHelper/
# awsAuthRefresh and all ANTHROPIC_* env keys so inherited settings can never
# shadow routing — routing/tier env is overlaid last by write_auth_env +
# write_model_env. Non-ANTHROPIC env keys (e.g. PERPLEXITY_API_KEY) are kept so
# inherited MCP servers keep working. Disable with DEEP_CLAUDE_STATUSLINE=0.
ensure_statusline() {
  [[ "${DEEP_CLAUDE_STATUSLINE:-1}" == "1" ]] || return 0
  command -v node >/dev/null 2>&1 || return 0
  local dest="$STATE_DIR/home/.claude/settings.json"
  local base=""
  if inherit_on && [[ -f "$HOME/.claude/settings.json" ]]; then
    base="$HOME/.claude/settings.json"
  elif [[ -f "$dest" && ! -L "$dest" ]]; then
    base="$dest"
  fi
  mkdir -p "$(dirname "$dest")"
  [[ -L "$dest" ]] && rm -f "$dest" # was a symlink from an older inherit run
  DC_DEST="$dest" DC_BASE="$base" DC_SCRIPT="$SCRIPT_DIR/deep-claude-statusline" node -e '
    const fs=require("fs");
    let s={}; try{ s=JSON.parse(fs.readFileSync(process.env.DC_BASE||process.env.DC_DEST,"utf8")); }catch(e){}
    delete s.model;
    delete s.apiKeyHelper;
    delete s.awsAuthRefresh;
    if(s.env){
      const safe={};
      for(const k of Object.keys(s.env)){
        if(!k.startsWith("ANTHROPIC_")) safe[k]=s.env[k];
      }
      s.env=safe;
    }
    if(!s.statusLine) s.statusLine={type:"command",command:process.env.DC_SCRIPT};
    fs.writeFileSync(process.env.DC_DEST, JSON.stringify(s,null,2));
  ' 2>/dev/null || true
}

# Persist the routing auth (base URL + token + key) into the isolated
# settings.json `env` block. Claude Code applies a settings `env` to every
# process that uses this config dir, so this is what keeps SUB-AGENTS, resumed
# sessions, and any background/fleet spawn authenticated. The launch env we
# export below only lives on the main process; a child that inherits a sanitized
# env (or a fresh `claude --resume`) would otherwise see no credentials and drop
# to `/login`. Re-written every launch because the proxy port is dynamic. In
# OpenRouter mode the token is the literal "router" (no real secret on disk —
# the upstream keys stay inside the proxy); in direct mode it's the endpoint key,
# which only ever lands in the git-ignored isolated home.
write_auth_env() {
  command -v node >/dev/null 2>&1 || return 0
  local dest="$STATE_DIR/home/.claude/settings.json"
  mkdir -p "$(dirname "$dest")"
  [[ -L "$dest" ]] && rm -f "$dest" # never write through a symlink into your real settings
  DC_DEST="$dest" DC_URL="$1" DC_AUTH="$2" DC_KEY="$3" node -e '
    const fs=require("fs");
    let s={}; try{ s=JSON.parse(fs.readFileSync(process.env.DC_DEST,"utf8")); }catch(e){}
    s.env=Object.assign({}, s.env, {
      ANTHROPIC_BASE_URL: process.env.DC_URL,
      ANTHROPIC_AUTH_TOKEN: process.env.DC_AUTH,
      ANTHROPIC_API_KEY: process.env.DC_KEY,
    });
    fs.writeFileSync(process.env.DC_DEST, JSON.stringify(s,null,2));
  ' 2>/dev/null || true
}

# Persist the 6 model-tier env vars into settings.json so sub-agents and
# resumed sessions use the same model tiers as the main process. Also removes
# any top-level `model` pin (which would shadow routing) and, in OpenRouter
# mode, sets the gateway-discovery and disable-betas flags.
# Signature: write_model_env <model> <opus> <sonnet> <haiku> <fable> <small_fast> <mode>
write_model_env() {
  command -v node >/dev/null 2>&1 || return 0
  local dest="$STATE_DIR/home/.claude/settings.json"
  mkdir -p "$(dirname "$dest")"
  [[ -L "$dest" ]] && rm -f "$dest"
  DC_DEST="$dest" \
  DC_MODEL="$1" DC_OPUS="$2" DC_SONNET="$3" DC_HAIKU="$4" DC_FABLE="$5" DC_SMALL="$6" \
  DC_MODE="$7" node -e '
    const fs=require("fs");
    let s={}; try{ s=JSON.parse(fs.readFileSync(process.env.DC_DEST,"utf8")); }catch(e){}
    delete s.model;
    s.env=Object.assign({}, s.env, {
      ANTHROPIC_MODEL: process.env.DC_MODEL,
      ANTHROPIC_DEFAULT_OPUS_MODEL: process.env.DC_OPUS,
      ANTHROPIC_DEFAULT_SONNET_MODEL: process.env.DC_SONNET,
      ANTHROPIC_DEFAULT_HAIKU_MODEL: process.env.DC_HAIKU,
      ANTHROPIC_DEFAULT_FABLE_MODEL: process.env.DC_FABLE,
      ANTHROPIC_SMALL_FAST_MODEL: process.env.DC_SMALL,
    });
    if(process.env.DC_MODE==="openrouter"){
      s.env.CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY="1";
      s.env.CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS="1";
    }
    fs.writeFileSync(process.env.DC_DEST, JSON.stringify(s,null,2));
  ' 2>/dev/null || true
  chmod 600 "$dest" 2>/dev/null || true
}

# Point Claude Code's state at our isolated home without touching $HOME (the
# macOS login keychain lives under $HOME/Library/Keychains).
set_claude_state() {
  mkdir -p "$STATE_DIR/home" "$STATE_DIR/config" "$STATE_DIR/cache" "$STATE_DIR/data" "$STATE_DIR/state"
  export CLAUDE_CONFIG_DIR="$STATE_DIR/home/.claude"
  export XDG_CONFIG_HOME="$STATE_DIR/config"
  export XDG_CACHE_HOME="$STATE_DIR/cache"
  export XDG_DATA_HOME="$STATE_DIR/data"
  export XDG_STATE_HOME="$STATE_DIR/state"
  # NB: use `if`, not `&& ...` — a false branch as the function's last command
  # would make set_claude_state return non-zero and, under set -e, abort runs.
  if [[ "${DEEP_CLAUDE_SHARE_SESSIONS:-1}" == "1" ]]; then share_sessions; fi
  if inherit_on; then inherit_config; fi
  ensure_statusline
}

# Global sandbox prefix array — populated by build_sandbox_prefix when
# DEEP_CLAUDE_SANDBOX=1; empty otherwise (expands to nothing in launch lines).
SANDBOX_PREFIX=()

# Build the OS-specific sandbox prefix (sets SANDBOX_PREFIX). Fails closed:
# if --sandbox was requested but the mechanism is unavailable, prints an error
# and exits non-zero — never silently runs unconfined.
# Usage: build_sandbox_prefix <proxy-port|"">
build_sandbox_prefix() {
  local port="${1:-}"
  if [[ "${DEEP_CLAUDE_SANDBOX:-0}" != "1" ]]; then
    SANDBOX_PREFIX=()
    return 0
  fi
  local os; os="$(uname -s)"
  case "$os" in
    Darwin)
      command -v sandbox-exec >/dev/null 2>&1 || { echo "deep-claude: --sandbox requested but sandbox-exec not found on PATH" >&2; exit 1; }
      # Choose network stanza in bash (no SBPL conditionals).
      local net_stanza
      if [[ "${DEEP_CLAUDE_SANDBOX_NET:-}" == "loopback" ]]; then
        net_stanza='(allow network-bind (local ip "localhost:*"))
(allow network-outbound (remote ip "localhost:*"))'
      else
        net_stanza='(allow network*)'
      fi
      # Generate the seatbelt profile with real absolute paths substituted.
      local sb="$STATE_DIR/seatbelt.sb"
      mkdir -p "$STATE_DIR"
      printf '(version 1)\n(deny default)\n(allow file-read*)\n(allow process-fork)\n(allow process-exec*)\n(allow signal (target children))\n(allow sysctl-read)\n(allow mach-lookup)\n(allow file-write*\n  (subpath "%s")\n  (subpath "%s")\n  (subpath "/private/tmp")\n  (subpath "/private/var/folders")\n  (subpath "/tmp")\n  (subpath "%s/.npm")\n  (subpath "%s/.cache")\n  (subpath "%s/Library/Caches")\n  (literal "/dev/null") (literal "/dev/stdout") (literal "/dev/stderr")\n  (regex #"^/dev/tty"))\n%s\n(allow network-outbound (remote unix-socket))\n' \
        "$PWD" "$STATE_DIR" "$HOME" "$HOME" "$HOME" "$net_stanza" >"$sb"
      SANDBOX_PREFIX=(sandbox-exec -f "$sb")
      ;;
    Linux)
      command -v bwrap >/dev/null 2>&1 || { echo "deep-claude: --sandbox requested but bwrap not found on PATH" >&2; exit 1; }
      SANDBOX_PREFIX=(bwrap --dev-bind / / --bind "$PWD" "$PWD" --bind "$STATE_DIR" "$STATE_DIR" --bind /tmp /tmp --share-net)
      ;;
    *)
      echo "deep-claude: --sandbox is not supported on $os" >&2; exit 1
      ;;
  esac
  return 0
}

# --- run: OpenRouter (default) ----------------------------------------------
run_openrouter() {
  local req_model="$1"; shift
  local args=("$@")

  command -v node >/dev/null 2>&1 || { echo "deep-claude: node is required for OpenRouter mode" >&2; exit 1; }

  # First run (no key or no models yet): walk setup, then carry on.
  local ran_wizard=""
  if [[ -z "$(resolve_openrouter_key)" || -z "$(env_get ROUTER_MODELS)" ]]; then
    run_setup || { echo "deep-claude: setup didn't complete." >&2; exit 1; }
    load_env
    ran_wizard=1
  fi

  local key; key="$(resolve_openrouter_key)"
  [[ -z "$key" ]] && { echo "deep-claude: setup didn't complete — no OpenRouter key." >&2; exit 1; }
  local model; model="$(resolve_router_model "$req_model")"
  [[ -z "$model" ]] && { echo "deep-claude: no model selected. Run 'deep-claude pick'." >&2; exit 1; }

  # Clear setup output so the session starts on a clean screen.
  [[ -n "$ran_wizard" ]] && { command -v clear >/dev/null 2>&1 && clear || printf '\033c'; }

  # Pick a free port — 8787 (or ROUTER_PORT) is often taken (wrangler/workerd, …).
  local host="${ROUTER_HOST:-127.0.0.1}"
  local port; port="$(find_free_port)"

  mkdir -p "$STATE_DIR"
  export_endpoint_keys   # so the proxy can route <provider>/* models directly
  ROUTER_PORT="$port" ROUTER_HOST="$host" OPENROUTER_API_KEY="$key" \
    node "$SCRIPT_DIR/deep-claude-proxy" >"$STATE_DIR/proxy.log" 2>&1 &
  local pid=$!
  trap 'kill "$pid" 2>/dev/null || true; wait "$pid" 2>/dev/null || true' EXIT INT TERM

  # Wait until OUR proxy answers (the /health marker guards against binding to
  # some unrelated service that happened to grab the port).
  local ready=""
  for _ in $(seq 1 50); do
    if curl -fsS "http://$host:$port/health" 2>/dev/null | grep -q 'deep-claude-proxy'; then ready=1; break; fi
    kill -0 "$pid" 2>/dev/null || { echo "deep-claude: proxy failed to start (see $STATE_DIR/proxy.log)." >&2; exit 1; }
    sleep 0.1
  done
  [[ -z "$ready" ]] && { echo "deep-claude: proxy did not become ready on http://$host:$port (see $STATE_DIR/proxy.log)." >&2; exit 1; }

  set_claude_state
  export ANTHROPIC_BASE_URL="http://$host:$port"
  export ANTHROPIC_AUTH_TOKEN="router"
  export ANTHROPIC_API_KEY=""
  export ANTHROPIC_MODEL="$model"
  # Persist the auth so sub-agents / resumed sessions stay logged in (see fn).
  write_auth_env "http://$host:$port" "router" ""
  # Map the switch slots (set by `deep-claude pick`) so /model can flip between
  # them in-session. An unset slot falls back to the current model.
  local s_opus s_sonnet s_haiku s_fable
  s_opus="$(env_get ROUTER_SLOT_OPUS)"; s_sonnet="$(env_get ROUTER_SLOT_SONNET)"
  s_haiku="$(env_get ROUTER_SLOT_HAIKU)"; s_fable="$(env_get ROUTER_SLOT_FABLE)"
  export ANTHROPIC_DEFAULT_OPUS_MODEL="${s_opus:-$model}"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="${s_sonnet:-$model}"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="${s_haiku:-$model}"
  export ANTHROPIC_DEFAULT_FABLE_MODEL="${s_fable:-$model}"
  export ANTHROPIC_SMALL_FAST_MODEL="${s_haiku:-$model}"
  export CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY="1"
  export CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS="1"
  # Persist model tiers so sub-agents / resumed sessions use the same models.
  write_model_env "$model" "${s_opus:-$model}" "${s_sonnet:-$model}" "${s_haiku:-$model}" "${s_fable:-$model}" "${s_haiku:-$model}" openrouter

  build_sandbox_prefix "$port"
  if ((${#args[@]})); then "${SANDBOX_PREFIX[@]+"${SANDBOX_PREFIX[@]}"}" "${CLAUDE_BIN:-claude}" --model "$model" "${args[@]}"; else "${SANDBOX_PREFIX[@]+"${SANDBOX_PREFIX[@]}"}" "${CLAUDE_BIN:-claude}" --model "$model"; fi
  exit $?
}

# --- run: personal endpoint (direct, no proxy) ------------------------------
run_endpoint() {
  local url="$1" key="$2" model="$3" name="$4"; shift 4
  local args=("$@")

  # Resolve this endpoint's configured models (interactive `endpoints add`) so
  # you can launch without --model and switch between them in-session.
  local models="" default="" slug=""
  if [[ -n "$name" ]]; then
    slug="$(ep_slug "$name")"
    models="$(env_get "DEEP_EP_MODELS_$slug")"
    default="$(env_get "DEEP_EP_DEFAULT_$slug")"
  fi
  [[ -z "$model" ]] && model="$default"
  [[ -z "$model" && -n "$models" ]] && model="${models%%,*}"
  if [[ -z "$model" ]]; then
    if [[ -n "$name" ]]; then
      echo "deep-claude: endpoint '$name' has no model. Pass --model <id>, or run 'deep-claude endpoints add' to configure models." >&2
    else
      echo "deep-claude: a personal endpoint needs --model <id>." >&2
    fi
    exit 1
  fi

  set_claude_state
  export ANTHROPIC_BASE_URL="$url"
  export ANTHROPIC_AUTH_TOKEN="${key:-none}"
  export ANTHROPIC_API_KEY="${key:-none}"
  export ANTHROPIC_MODEL="$model"
  # Persist the auth so sub-agents / resumed sessions stay logged in (see fn).
  write_auth_env "$url" "${key:-none}" "${key:-none}"

  # Map the endpoint's models onto Claude Code's /model switch slots so you can
  # flip between them in-session. Prefer the explicit per-slot assignments set in
  # the picker (DEEP_EP_SLOT_<TIER>_<slug>); if none were set, fall back to list
  # order (opus/sonnet/haiku/fable). Any unfilled slot falls back to the launch
  # model. (ANTHROPIC_SMALL_FAST_MODEL is the deprecated alias of HAIKU; we still
  # set it so older Claude Code builds keep working.)
  local t_opus="$model" t_sonnet="$model" t_haiku="$model" t_fable="$model"
  if [[ -n "$models" ]]; then
    local ms sl_o sl_s sl_h sl_f
    IFS=',' read -ra ms <<<"$models"
    if [[ -n "$slug" ]]; then
      sl_o="$(env_get "DEEP_EP_SLOT_OPUS_$slug")"; sl_s="$(env_get "DEEP_EP_SLOT_SONNET_$slug")"
      sl_h="$(env_get "DEEP_EP_SLOT_HAIKU_$slug")"; sl_f="$(env_get "DEEP_EP_SLOT_FABLE_$slug")"
    fi
    if [[ -n "${sl_o:-}${sl_s:-}${sl_h:-}${sl_f:-}" ]]; then
      t_opus="${sl_o:-$model}"; t_sonnet="${sl_s:-$model}"
      t_haiku="${sl_h:-$model}"; t_fable="${sl_f:-$model}"
    else
      t_opus="${ms[0]:-$model}"; t_sonnet="${ms[1]:-$model}"
      t_haiku="${ms[2]:-$model}"; t_fable="${ms[3]:-$model}"
    fi
  fi
  export ANTHROPIC_DEFAULT_OPUS_MODEL="$t_opus"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="$t_sonnet"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="$t_haiku"
  export ANTHROPIC_DEFAULT_FABLE_MODEL="$t_fable"
  export ANTHROPIC_SMALL_FAST_MODEL="$t_haiku"
  # Persist model tiers so sub-agents / resumed sessions use the same models.
  write_model_env "$model" "$t_opus" "$t_sonnet" "$t_haiku" "$t_fable" "$t_haiku" endpoint

  build_sandbox_prefix ""
  if ((${#args[@]})); then exec "${SANDBOX_PREFIX[@]+"${SANDBOX_PREFIX[@]}"}" "${CLAUDE_BIN:-claude}" --model "$model" "${args[@]}"; else exec "${SANDBOX_PREFIX[@]+"${SANDBOX_PREFIX[@]}"}" "${CLAUDE_BIN:-claude}" --model "$model"; fi
}

# --- run dispatch -----------------------------------------------------------
run_main() {
  local model="" endpoint="" base_url="" api_key="" api_key_env=""
  local args=()
  while (($#)); do
    case "$1" in
      --) shift; while (($#)); do args+=("$1"); shift; done ;;
      --model) [[ $# -lt 2 ]] && { echo "deep-claude: --model needs a value" >&2; exit 2; }; model="$2"; shift 2 ;;
      --model=*) model="${1#--model=}"; shift ;;
      --endpoint) [[ $# -lt 2 ]] && { echo "deep-claude: --endpoint needs a name" >&2; exit 2; }; endpoint="$2"; shift 2 ;;
      --endpoint=*) endpoint="${1#--endpoint=}"; shift ;;
      --base-url) [[ $# -lt 2 ]] && { echo "deep-claude: --base-url needs a URL" >&2; exit 2; }; base_url="$2"; shift 2 ;;
      --base-url=*) base_url="${1#--base-url=}"; shift ;;
      --api-key) [[ $# -lt 2 ]] && { echo "deep-claude: --api-key needs a value" >&2; exit 2; }; api_key="$2"; shift 2 ;;
      --api-key=*) api_key="${1#--api-key=}"; shift ;;
      --api-key-env) [[ $# -lt 2 ]] && { echo "deep-claude: --api-key-env needs a var name" >&2; exit 2; }; api_key_env="$2"; shift 2 ;;
      --api-key-env=*) api_key_env="${1#--api-key-env=}"; shift ;;
      --inherit) export DEEP_CLAUDE_INHERIT=1; shift ;;
      --no-inherit) export DEEP_CLAUDE_INHERIT=0; shift ;;
      --share-sessions) export DEEP_CLAUDE_SHARE_SESSIONS=1; shift ;;
      --no-share-sessions) export DEEP_CLAUDE_SHARE_SESSIONS=0; shift ;;
      --sandbox) export DEEP_CLAUDE_SANDBOX=1; shift ;;
      --no-sandbox) export DEEP_CLAUDE_SANDBOX=0; shift ;;
      *) args+=("$1"); shift ;;
    esac
  done

  # Saved endpoint -> resolve into base_url + key env.
  if [[ -n "$endpoint" ]]; then
    local spec; spec="$(endpoint_lookup "$endpoint")" || { echo "deep-claude: no saved endpoint '$endpoint' (see: deep-claude endpoints list)" >&2; exit 1; }
    base_url="${spec%%|*}"
    api_key_env="${spec#*|}"
  fi

  if [[ -n "$base_url" ]]; then
    # Resolve the key: explicit --api-key wins; otherwise, for a saved endpoint
    # use the full chain (shell env, .env, then Keychain) so a key stored by the
    # picker — which defaults to the Keychain — is actually found. For a bare
    # --base-url (no endpoint name, hence no Keychain account) fall back to
    # env/.env only.
    local key="$api_key"
    if [[ -z "$key" ]]; then
      if [[ -n "$endpoint" ]]; then
        key="$(resolve_endpoint_key "$endpoint" "$api_key_env")"
      elif [[ -n "$api_key_env" ]]; then
        key="${!api_key_env:-}"
        [[ -z "$key" ]] && key="$(env_get "$api_key_env")"
      fi
    fi
    run_endpoint "$base_url" "$key" "$model" "$endpoint" ${args[@]+"${args[@]}"}
  else
    run_openrouter "$model" ${args[@]+"${args[@]}"}
  fi
}

# --- top-level dispatch -----------------------------------------------------
load_env
case "${1:-}" in
  cli | setup) shift; run_setup interactive ;;
  pick) shift; run_pick ;;
  models) shift; models_dispatch "$@" ;;
  endpoints) shift; endpoints_dispatch "$@" ;;
  serve) shift; exec node "$SCRIPT_DIR/deep-claude-proxy" "$@" ;;
  -h | --help | help) usage ;;
  *) run_main "$@" ;;
esac
