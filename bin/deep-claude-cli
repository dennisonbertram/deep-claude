#!/usr/bin/env node
'use strict';

// deep-claude-cli — the key-entry step of first-run setup. Collects an
// OpenRouter key and stores it (Keychain or .env). The model picker runs
// separately (the `deep-claude` wrapper sequences it), which keeps each TUI in
// its own clean process. Invoked by `deep-claude cli` and on first run.
//
// Env (set by the `deep-claude` wrapper):
//   OPENROUTER_API_KEY    the already-resolved key, if any (then this is a no-op).
//   DEEP_CLAUDE_ENV_FILE  the .env file to write to.

const path = require('path');
const fs = require('fs');
const { spawnSync } = require('child_process');

const ENV_FILE = process.env.DEEP_CLAUDE_ENV_FILE || path.join(process.cwd(), '.env');
const haveKey = !!(process.env.OPENROUTER_API_KEY && process.env.OPENROUTER_API_KEY !== 'sk-or-...');

const out = process.stdout;
const C = {
  reset: '\x1b[0m', bold: '\x1b[1m', dim: '\x1b[2m',
  green: '\x1b[32m', cyan: '\x1b[36m', gray: '\x1b[90m',
};

function clear() { out.write('\x1b[2J\x1b[3J\x1b[H'); }
function header() {
  clear();
  out.write(`\n  ${C.cyan}${C.bold}deep-claude${C.reset} ${C.gray}🐋  setup${C.reset}\n`);
  out.write(`  ${C.gray}${'─'.repeat(54)}${C.reset}\n\n`);
}
function setupRaw() { if (process.stdin.isTTY) process.stdin.setRawMode(true); process.stdin.resume(); }
function teardownRaw() { if (process.stdin.isTTY) process.stdin.setRawMode(false); process.stdin.pause(); }

function promptText({ label, hint, mask }) {
  return new Promise((resolve) => {
    let value = '';
    const render = () => {
      header();
      out.write(`  ${C.bold}${label}${C.reset}\n`);
      if (hint) out.write(`  ${C.gray}${hint}${C.reset}\n`);
      out.write(`\n  ${C.green}❯${C.reset} ${mask ? '•'.repeat(value.length) : value}${C.gray}▏${C.reset}\n`);
      out.write(`\n  ${C.gray}↵ continue · esc cancel${C.reset}`);
    };
    const onKey = (buf) => {
      const s = buf.toString();
      let i = 0, dirty = false;
      while (i < s.length) {
        let k;
        if (s[i] === '\x1b' && s[i + 1] === '[') { k = s.slice(i, i + 3); i += 3; }
        else { k = s[i]; i += 1; }
        if (k === '\x03' || k === '\x1b') { process.stdin.removeListener('data', onKey); return resolve(null); }
        if (k === '\r' || k === '\n') { process.stdin.removeListener('data', onKey); return resolve(value.trim()); }
        if (k === '\x7f' || k === '\b') { value = value.slice(0, -1); dirty = true; continue; }
        if (k.length === 1 && k >= ' ' && k <= '~') { value += k; dirty = true; continue; }
      }
      if (dirty) render();
    };
    process.stdin.on('data', onKey);
    render();
  });
}

function promptSelect({ label, options }) {
  return new Promise((resolve) => {
    let cursor = 0;
    const render = () => {
      header();
      out.write(`  ${C.bold}${label}${C.reset}\n\n`);
      options.forEach((o, idx) => {
        const cur = idx === cursor;
        const dot = cur ? `${C.green}●${C.reset}` : `${C.gray}○${C.reset}`;
        out.write(`  ${dot} ${cur ? `${C.bold}${o.label}${C.reset}` : o.label}${o.hint ? `  ${C.gray}${o.hint}${C.reset}` : ''}\n`);
      });
      out.write(`\n  ${C.gray}↑/↓ move · ↵ choose · esc cancel${C.reset}`);
    };
    const onKey = (buf) => {
      const s = buf.toString();
      let i = 0, dirty = false;
      while (i < s.length) {
        let k;
        if (s[i] === '\x1b' && s[i + 1] === '[') { k = s.slice(i, i + 3); i += 3; }
        else { k = s[i]; i += 1; }
        if (k === '\x03' || k === '\x1b') { process.stdin.removeListener('data', onKey); return resolve(null); }
        if (k === '\r' || k === '\n') { process.stdin.removeListener('data', onKey); return resolve(cursor); }
        if (k === '\x1b[A') { cursor = (cursor - 1 + options.length) % options.length; dirty = true; continue; }
        if (k === '\x1b[B') { cursor = (cursor + 1) % options.length; dirty = true; continue; }
      }
      if (dirty) render();
    };
    process.stdin.on('data', onKey);
    render();
  });
}

function envSet(key, value) {
  let lines = [];
  if (fs.existsSync(ENV_FILE)) lines = fs.readFileSync(ENV_FILE, 'utf8').split('\n');
  let found = false;
  lines = lines.map((l) => (l.startsWith(key + '=') ? ((found = true), `${key}="${value}"`) : l));
  if (!found) {
    if (lines.length && lines[lines.length - 1] === '') lines.splice(lines.length - 1, 0, `${key}="${value}"`);
    else lines.push(`${key}="${value}"`);
  }
  fs.writeFileSync(ENV_FILE, lines.join('\n'));
}

function storeKeychain(key) {
  const r = spawnSync('security',
    ['add-generic-password', '-s', 'deep-router', '-a', 'openrouter', '-U', '-w', key],
    { stdio: 'ignore' });
  return r.status === 0;
}

async function main() {
  if (haveKey) { process.exit(0); } // nothing to collect

  out.write('\x1b[?25l'); // hide cursor
  setupRaw();

  const key = await promptText({
    label: 'Paste your OpenRouter API key',
    hint: 'Get one at https://openrouter.ai/keys  ·  input is hidden',
    mask: true,
  });
  if (!key) { teardownRaw(); out.write('\x1b[?25h'); clear(); out.write('Setup cancelled.\n'); process.exit(1); }

  let where = 1;
  if (process.platform === 'darwin') {
    const sel = await promptSelect({
      label: 'Where should I store the key?',
      options: [
        { label: 'macOS Keychain', hint: 'recommended — never written to disk in plaintext' },
        { label: '.env file', hint: ENV_FILE },
      ],
    });
    if (sel === null) { teardownRaw(); out.write('\x1b[?25h'); clear(); out.write('Setup cancelled.\n'); process.exit(1); }
    where = sel;
  }

  teardownRaw();
  out.write('\x1b[?25h'); // show cursor

  let stored;
  if (where === 0 && storeKeychain(key)) stored = 'macOS Keychain';
  else { envSet('OPENROUTER_API_KEY', key); stored = ENV_FILE; }

  header();
  out.write(`  ${C.green}✓${C.reset} OpenRouter key saved to ${C.bold}${stored}${C.reset}\n\n`);
  process.exit(0);
}

main().catch((e) => { teardownRaw(); out.write('\x1b[?25h'); console.error(e); process.exit(1); });
