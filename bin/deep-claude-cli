#!/usr/bin/env node
'use strict';

// deep-claude-cli — the first-run setup wizard. Collects an OpenRouter key,
// stores it (Keychain or .env), then runs the model picker. Invoked by
// `deep-claude cli`, and automatically on first run when no key is configured.
//
// Env (set by the `deep-claude` wrapper):
//   OPENROUTER_API_KEY    the already-resolved key, if any (skip the key step).
//   DEEP_CLAUDE_ENV_FILE  the .env file to write to.

const path = require('path');
const fs = require('fs');
const { spawnSync } = require('child_process');

const ENV_FILE = process.env.DEEP_CLAUDE_ENV_FILE || path.join(process.cwd(), '.env');
const PICKER = path.join(__dirname, 'deep-claude-pick');
const haveKey = !!(process.env.OPENROUTER_API_KEY && process.env.OPENROUTER_API_KEY !== 'sk-or-...');

const out = process.stdout;
const C = {
  reset: '\x1b[0m', bold: '\x1b[1m', dim: '\x1b[2m', inv: '\x1b[7m',
  green: '\x1b[32m', cyan: '\x1b[36m', yellow: '\x1b[33m', blue: '\x1b[34m',
  red: '\x1b[31m', gray: '\x1b[90m',
};

function clear() { out.write('\x1b[2J\x1b[3J\x1b[H'); }
function hideCursor() { out.write('\x1b[?25l'); }
function showCursor() { out.write('\x1b[?25h'); }

function header(step, total) {
  clear();
  out.write(`\n  ${C.cyan}${C.bold}deep-claude${C.reset} ${C.gray}🐋  setup${C.reset}\n`);
  out.write(`  ${C.gray}${'─'.repeat(54)}${C.reset}\n`);
  if (step) out.write(`  ${C.dim}step ${step} of ${total}${C.reset}\n`);
  out.write('\n');
}

function setupRaw() {
  if (process.stdin.isTTY) process.stdin.setRawMode(true);
  process.stdin.resume();
}
function teardownRaw() {
  if (process.stdin.isTTY) process.stdin.setRawMode(false);
  process.stdin.pause();
}

// Masked / plain single-line input. Resolves to the string, or null on cancel.
function promptText({ label, hint, mask }) {
  return new Promise((resolve) => {
    let value = '';
    const render = () => {
      header(1, 2);
      out.write(`  ${C.bold}${label}${C.reset}\n`);
      if (hint) out.write(`  ${C.gray}${hint}${C.reset}\n`);
      out.write('\n');
      const shown = mask ? '•'.repeat(value.length) : value;
      out.write(`  ${C.green}❯${C.reset} ${shown}${C.gray}▏${C.reset}\n`);
      out.write(`\n  ${C.gray}↵ continue · esc cancel${C.reset}`);
    };
    const onKey = (buf) => {
      const s = buf.toString();
      let i = 0;
      let dirty = false;
      while (i < s.length) {
        let k;
        if (s[i] === '\x1b' && s[i + 1] === '[') { k = s.slice(i, i + 3); i += 3; }
        else { k = s[i]; i += 1; }
        if (k === '\x03' || k === '\x1b') { process.stdin.removeListener('data', onKey); return resolve(null); }
        if (k === '\r' || k === '\n') { process.stdin.removeListener('data', onKey); return resolve(value.trim()); }
        if (k === '\x7f' || k === '\b') { value = value.slice(0, -1); dirty = true; continue; }
        if (k.length === 1 && k >= ' ' && k <= '~') { value += k; dirty = true; continue; }
      }
      if (dirty) render();
    };
    process.stdin.on('data', onKey);
    render();
  });
}

// Vertical select. Resolves to the chosen index, or null on cancel.
function promptSelect({ label, options }) {
  return new Promise((resolve) => {
    let cursor = 0;
    const render = () => {
      header(1, 2);
      out.write(`  ${C.bold}${label}${C.reset}\n\n`);
      options.forEach((o, idx) => {
        const cur = idx === cursor;
        const dot = cur ? `${C.green}●${C.reset}` : `${C.gray}○${C.reset}`;
        const text = cur ? `${C.bold}${o.label}${C.reset}` : o.label;
        out.write(`  ${dot} ${text}${o.hint ? `  ${C.gray}${o.hint}${C.reset}` : ''}\n`);
      });
      out.write(`\n  ${C.gray}↑/↓ move · ↵ choose · esc cancel${C.reset}`);
    };
    const onKey = (buf) => {
      const s = buf.toString();
      let i = 0;
      let dirty = false;
      while (i < s.length) {
        let k;
        if (s[i] === '\x1b' && s[i + 1] === '[') { k = s.slice(i, i + 3); i += 3; }
        else { k = s[i]; i += 1; }
        if (k === '\x03' || k === '\x1b') { process.stdin.removeListener('data', onKey); return resolve(null); }
        if (k === '\r' || k === '\n') { process.stdin.removeListener('data', onKey); return resolve(cursor); }
        if (k === '\x1b[A') { cursor = (cursor - 1 + options.length) % options.length; dirty = true; continue; }
        if (k === '\x1b[B') { cursor = (cursor + 1) % options.length; dirty = true; continue; }
      }
      if (dirty) render();
    };
    process.stdin.on('data', onKey);
    render();
  });
}

function envSet(key, value) {
  let lines = [];
  if (fs.existsSync(ENV_FILE)) lines = fs.readFileSync(ENV_FILE, 'utf8').split('\n');
  let found = false;
  lines = lines.map((l) => (l.startsWith(key + '=') ? ((found = true), `${key}="${value}"`) : l));
  if (!found) {
    if (lines.length && lines[lines.length - 1] === '') lines.splice(lines.length - 1, 0, `${key}="${value}"`);
    else lines.push(`${key}="${value}"`);
  }
  fs.writeFileSync(ENV_FILE, lines.join('\n'));
}

function storeKeychain(key) {
  const r = spawnSync('security',
    ['add-generic-password', '-s', 'deep-router', '-a', 'openrouter', '-U', '-w', key],
    { stdio: 'ignore' });
  return r.status === 0;
}

async function main() {
  hideCursor();
  setupRaw();

  // --- Step 1: key ---------------------------------------------------------
  if (!haveKey) {
    const key = await promptText({
      label: 'Paste your OpenRouter API key',
      hint: 'Get one at https://openrouter.ai/keys  ·  input is hidden',
      mask: true,
    });
    if (key === null || key === '') { teardownRaw(); showCursor(); clear(); out.write('Setup cancelled.\n'); process.exit(1); }

    let where = 0;
    if (process.platform === 'darwin') {
      where = await promptSelect({
        label: 'Where should I store the key?',
        options: [
          { label: 'macOS Keychain', hint: 'recommended — never touches disk in plaintext' },
          { label: '.env file', hint: `${ENV_FILE}` },
        ],
      });
      if (where === null) { teardownRaw(); showCursor(); clear(); out.write('Setup cancelled.\n'); process.exit(1); }
    } else {
      where = 1; // no Keychain off macOS
    }

    if (where === 0 && storeKeychain(key)) {
      process.env.OPENROUTER_API_KEY = key;
    } else {
      envSet('OPENROUTER_API_KEY', key);
      process.env.OPENROUTER_API_KEY = key;
    }
  }

  teardownRaw();
  showCursor();

  // --- Step 2: models (hand off to the picker) -----------------------------
  header(2, 2);
  out.write(`  ${C.green}✓${C.reset} OpenRouter key ready. Now choose your models…\n\n`);
  const r = spawnSync(process.execPath, [PICKER], {
    stdio: 'inherit',
    env: { ...process.env, DEEP_CLAUDE_ENV_FILE: ENV_FILE },
  });
  if (r.status !== 0) process.exit(r.status || 1);

  // --- Done ----------------------------------------------------------------
  out.write(`\n  ${C.green}${C.bold}You're all set.${C.reset}\n`);
  out.write(`  ${C.gray}Run${C.reset} ${C.bold}deep-claude${C.reset} ${C.gray}to start, or${C.reset} ${C.bold}deep-claude --model <alias>${C.reset} ${C.gray}for a specific one.${C.reset}\n\n`);
  process.exit(0);
}

main().catch((e) => { teardownRaw(); showCursor(); console.error(e); process.exit(1); });
